[Unit]
Description=Antigravity Dreamer — daily strategic analysis
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=antigravity-ai
WorkingDirectory=/home/antigravity-ai/Antigravity_Orchestra
ExecStart=/home/antigravity-ai/Antigravity_Orchestra/run_cron.sh dreamer_daily_serverside.py
TimeoutStartSec=600
StandardOutput=append:/home/antigravity-ai/Antigravity_Orchestra/logs/dreamer-daily.log
StandardError=append:/home/antigravity-ai/Antigravity_Orchestra/logs/dreamer-daily.log
